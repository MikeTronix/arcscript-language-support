{
  "comments": {
    "lineComment": "//",
    "blockComment": ["##", ""]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(~if|~elif|~else|~unknown|~when|~unless|~define|~func|~auto|~triggers|~recipes|~minigame)\\b",
    "decreaseIndentPattern": "^\\s*(~end|~elif|~else|~unknown)\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.]*",
  "folding": {
    "markers": {
      "start": "^\\s*(===|~define|~func|~triggers|~recipes|~minigame)\\b",
      "end": "^\\s*(===|~end)\\s*$"
    }
  }
}
